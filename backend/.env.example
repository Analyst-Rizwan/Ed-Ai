# =========================================
# EDUAI BACKEND — ENVIRONMENT CONFIGURATION
# =========================================
# Copy this file to: backend/.env
# Fill in all required values before starting the server.
# =========================================

# === APP SETTINGS ===
APP_NAME=EduAi
APP_ENV=development                  # "development" | "production"
APP_PORT=8000

# === DATABASE CONFIGURATION ===
# SQLite (local development)
DATABASE_URL=sqlite:///./eduai.db

# PostgreSQL (production) — uncomment and fill in:
# DATABASE_URL=postgresql://username:password@host:5432/dbname

# === SECURITY & AUTH ===
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30       # 30 min recommended for production
REFRESH_TOKEN_EXPIRE_DAYS=7

# === AI PROVIDER SELECTION ===
# Choose: "gemini" or "openai"
AI_PROVIDER=openai

# === OPENAI CONFIGURATION ===
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# === GEMINI CONFIGURATION ===
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# === AI SYSTEM PROMPT ===
AI_SYSTEM_PROMPT="You are EduAi, a friendly, adaptive AI mentor who simplifies complex topics."

# === CORS SETTINGS ===
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# === SUPABASE (optional, for production database) ===
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_JWT_SECRET=your-jwt-secret

# === LOGGING / DEBUG ===
DEBUG=True
LOG_LEVEL=info

# === DEPLOYMENT SETTINGS ===
HOST=0.0.0.0
PORT=8000
WORKERS=4
