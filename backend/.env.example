# ============================================================
# Ed-AI Backend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# === Database (REQUIRED) ===
# Use your Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-....pooler.supabase.com:6543/postgres

# === Security ===
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === AI Provider ===
AI_PROVIDER=gemini
# OPENAI_API_KEY=sk-...
GEMINI_API_KEY=your-gemini-api-key

# === Resend (transactional emails — password reset, welcome, etc.) ===
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=EduAI <noreply@yourdomain.com>

# === GitHub OAuth (for 1-click deploy) ===
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# === App settings ===
APP_ENV=development
DEBUG=True
LOG_LEVEL=info
