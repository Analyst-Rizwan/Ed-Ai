# ============================================================
# Ed-AI Backend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# === Database (REQUIRED) ===
# Use your Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-....pooler.supabase.com:6543/postgres

# === Security ===
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === AI Provider ===
AI_PROVIDER=gemini
# OPENAI_API_KEY=sk-...
GEMINI_API_KEY=your-gemini-api-key

# === SMTP (for password reset OTP emails) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# === GitHub OAuth (for 1-click deploy) ===
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# === App settings ===
APP_ENV=development
DEBUG=True
LOG_LEVEL=info
